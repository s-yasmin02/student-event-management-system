  },
  "item": [
    {
      "name": "Events",
      "item": [
        {
          "name": "Get All Events",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "events"]
            }
          }
        },

        {
          "name": "Create Event (Raw JSON)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Annual Tech Symposium 2026\",\n  \"category\": \"Technology\",\n  \"location\": \"Main Auditorium\",\n  \"date\": \"2026-05-20\",\n  \"registrationDeadline\": \"2026-05-15\",\n  \"capacity\": 250,\n  \"description\": \"Join us for the biggest tech event of the year!\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "http://localhost:5000/api/events",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "Update Event",
          "request": {
            "method": "PUT",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "title",
                  "value": "Updated Tech Conference",
                  "type": "text"
                },
                {
                  "key": "capacity",
                  "value": "600",
                  "type": "text"
                },
                {
                  "key": "image",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "http://localhost:5000/api/events/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "events", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "YOUR_EVENT_ID_HERE"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Event",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/events/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "events", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "YOUR_EVENT_ID_HERE"
                }
              ]
